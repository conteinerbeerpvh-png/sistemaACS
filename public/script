// Exportar todos os cadastros em PDF
async function exportarTodosPDF() {
    try {
        const response = await fetch('/api/cadastros');
        const todosCadastros = await response.json();
        
        const conteudo = `
            <div style="padding: 20px; font-family: Arial;">
                <h2 style="color: #333;">Relatório Completo - Cadastros ACS</h2>
                <p>Total de cadastros: ${todosCadastros.length}</p>
                <hr>
                ${todosCadastros.map(cadastro => `
                    <div style="margin-bottom: 20px; padding: 10px; border: 1px solid #ddd;">
                        <p><strong>Nome:</strong> ${cadastro.nomeCompleto}</p>
                        <p><strong>CPF:</strong> ${cadastro.cpf}</p>
                        <p><strong>Telefone:</strong> ${cadastro.telefone}</p>
                        <p><strong>Endereço:</strong> ${cadastro.endereco}</p>
                        <p><strong>Comodidade:</strong> ${cadastro.comodidade}</p>
                        <p><strong>Data Nasc.:</strong> ${formatarData(cadastro.dataNascimento)}</p>
                    </div>
                `).join('')}
            </div>
        `;
        
        const element = document.createElement('div');
        element.innerHTML = conteudo;
        
        html2pdf().from(element).save('relatorio-completo-acs.pdf');
    } catch (error) {
        alert('Erro ao exportar PDF');
    }
}

// Enviar via WhatsApp
function enviarWhatsApp(telefone, nome) {
    const numero = telefone.replace(/\D/g, '');
    const mensagem = encodeURIComponent(`Olá ${nome}! Sou ACS da sua região.`);
    window.open(`https://wa.me/55${numero}?text=${mensagem}`, '_blank');
}

// Editar cadastro
async function editarCadastro(id) {
    const cadastro = cadastros.find(c => c._id === id);
    if (!cadastro) return;
    
    // Preencher formulário com dados do cadastro
    document.getElementById('nomeCompleto').value = cadastro.nomeCompleto;
    document.getElementById('dataNascimento').value = cadastro.dataNascimento.split('T')[0];
    document.getElementById('cpf').value = cadastro.cpf;
    document.getElementById('telefone').value = cadastro.telefone;
    document.getElementById('endereco').value = cadastro.endereco;
    document.getElementById('comodidade').value = cadastro.comodidade;
    
    // Alterar botão para atualizar
    const form = document.getElementById('cadastroForm');
    const submitBtn = form.querySelector('button[type="submit"]');
    submitBtn.innerHTML = '<i class="fas fa-sync"></i> Atualizar Cadastro';
    
    // Remover evento anterior e adicionar novo
    const newForm = form.cloneNode(true);
    form.parentNode.replaceChild(newForm, form);
    
    newForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const dadosAtualizados = {
            nomeCompleto: document.getElementById('nomeCompleto').value,
            dataNascimento: document.getElementById('dataNascimento').value,
            cpf: document.getElementById('cpf').value,
            telefone: document.getElementById('telefone').value,
            endereco: document.getElementById('endereco').value,
            comodidade: document.getElementById('comodidade').value
        };
        
        try {
            const response = await fetch(`/api/cadastros/${id}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(dadosAtualizados)
            });
            
            if (response.ok) {
                alert('Cadastro atualizado com sucesso!');
                location.reload();
            }
        } catch (error) {
            alert('Erro ao atualizar cadastro');
        }
    });
}

// Carregar cadastros ao iniciar
buscarCadastros();
